<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.juseop.portfolio.mapper.SkillMapper">

    <resultMap id="SkillCategoryResultMap" type="SkillCategory">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="description" column="description"/>
        <result property="displayOrder" column="display_order"/>
    </resultMap>

    <select id="findAllCategories" resultMap="SkillCategoryResultMap">
        SELECT id, title, description, display_order
        FROM skill_categories
        ORDER BY display_order ASC
    </select>

    <select id="findSkillsByCategoryId" resultType="String">
        SELECT name
        FROM skills
        WHERE category_id = #{categoryId}
        ORDER BY display_order ASC
    </select>

</mapper>
